{
    // Place your snippets for sql here. Each snippet is defined under a snippet name and has a prefix, body and
    // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
    // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
    // same ids are connected.
    // Example:
    // "Print to console": {
    // 	"prefix": "log",
    // 	"body": [
    // 		"console.log('$1');",
    // 		"$2"
    // 	],
    // 	"description": "Log output to console"
    // }
    "Selector": {
        "prefix": "ssf",
        "body": [
            "SELECT * FROM $0"
        ],
        "description": "Select some stuff"
    },
    "employer": {
        "prefix": "pwer",
        "body": [
            "SELECT $0 FROM EmployerIdentification"
        ],
        "description": "Select some company stuff"
    },
    "employee": {
        "prefix": "pwei",
        "body": [
            "SELECT $0 FROM EmployeeIdentification"
        ],
        "description": "Select some employee stuff"
    },
    "PayDatabase Path": {
        "prefix": "paydb",
        "body": [
            "SELECT PayDatabasePath FROM EmployerIdentification"
        ],
        "description": "Find paydatabase reports"
    },
    "Help": {
        "prefix": "help",
        "body": [
            "EXEC sp_help"
        ],
        "description": "I need somebody..."
    }
}
